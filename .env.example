# Optional: set a server-side fallback key for local dev or a hosted demo.
# The app is BYOK by default: the browser key is stored only in localStorage.
#
# Default provider: OpenRouter
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: point the app at an OpenAI-compatible relay or proxy instead of
# OpenRouter directly. Accepts either a /v1 base URL or a full
# /chat/completions URL.
# Example: https://your-relay.example/v1
OPENROUTER_BASE_URL=

# Optional aliases also supported:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
